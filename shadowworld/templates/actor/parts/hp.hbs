<h2>HP</h2>

<div class="hp">

  <div>
    <label>Current</label>
    <input type="number"
           name="system.hp.current"
           value="{{system.hp.current}}">
  </div>

  <div>
    <label>Max</label>
    <input type="number"
           name="system.hp.max"
           value="{{system.hp.max}}">
  </div>

  <div>
    <label>Non-lethal</label>
    <input type="number"
           name="system.hp.nonlethal"
           value="{{system.hp.nonlethal}}">
  </div>

</div>
<form>
  {{#if isInitiative}}
   <h3>Initiative Roll</h3>
  {{/if}}

  {{#if showAttribute}}
  <div class="form-group">
    <label>Attribute</label>
    <select name="attribute">
      {{#each attributes}}
        <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>
          {{this.label}}
        </option>
      {{/each}}
    </select>
  </div>
  {{/if}}

  {{#if showSkill}}
  <div class="form-group">
    <label>Skill</label>
    <select name="skill">
        {{#if showSkillNone}}
          <option value="">---None---</option>
        {{/if}}
      {{#each skills}}
        <option value="{{this.name}}" {{#if this.selected}}selected{{/if}}>
          {{this.name}}
        </option>
      {{/each}}
    </select>
  </div>
  {{/if}}

  {{#if showSkillFixed}}
    <div class="form-group">
    <label>Skill</label>
    <p><b>{{skillName}}</b></p>
    </div>
  {{/if}}

  {{#if showWeapon}}
  <div class="form-group">
    <label>Weapon</label>
    <p><b>{{weapon.name}}</b></p>
  </div>
  {{/if}}

  {{#if showItemSelect}}
  <div class="form-group">
    <label>Item</label>
    <select name="item">
        <option value="">---None---</option>
      {{#each items}}
        <option value="{{this.id}}">{{this.name}}</option>
      {{/each}}
    </select>
  </div>
  {{/if}}

  

  <div class="form-group">
    <label>Modifier</label>
    <input type="number" name="modifier" value="0">
  </div>

  <div class="form-group">
    <label>Mode</label>
    <select name="mode">
      <option value="normal">Normal</option>
      <option value="advantage">Advantage</option>
      <option value="disadvantage">Disadvantage</option>
    </select>
  </div>

</form>